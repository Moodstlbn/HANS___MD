# ┌─────────────────────────────────────────────────────────┐
# │             HANS MD — Configuration Template            │
# │  Rename this file to .env and fill in your details.    │
# └─────────────────────────────────────────────────────────┘


# ── Authentication ────────────────────────────────────────
# Provide SESSION_ID OR OWNER_NUMBER (not both required).
#
# Option A: Cloud Session ID (pre-linked, fastest setup)
#   Get yours at: http://34.39.174.93:3000
SESSION_ID=""

# Option B: Your WhatsApp phone number with country code
#   Used for the interactive pairing-code flow on first boot.
#   Leave empty if using SESSION_ID.
OWNER_NUMBER=""

# Cloud vault URL (change only if you self-host the vault)
PAIRING_SERVER_URL="http://34.39.174.93:3000"


# ── Bot Identity ──────────────────────────────────────────
BOT_NAME="HANS MD"
OWNER_NAME="Harold"

# Command prefix — single char or comma-separated list (e.g. ".,!")
PREFIX="."

# GitHub repo link shown in bot menus
GITHUB_URL="https://github.com/haroldmth/hans___md"


# ── Automation Features ───────────────────────────────────
# All default to false for privacy — enable only what you need.

# React with a random emoji to every incoming message
AUTO_REACT="false"

# Forward deleted messages back to owner DM
# Values: false | true | dm | group | both
ANTI_DELETE="false"

# Mark all incoming messages as read automatically
AUTO_READ="false"

# Auto-view status updates
AUTO_STATUS="false"

# Auto-react (like) to status updates with a random emoji
AUTO_STATUS_LIKE="false"

# Show typing indicator while processing commands
AUTO_TYPING="false"

# Show audio-recording indicator while processing commands
AUTO_RECORDING="false"

# Keep WhatsApp presence permanently shown as Online
ALWAYS_ONLINE="false"


# ── Database & Privacy ────────────────────────────────────
# AES-256-CBC key to encrypt database/messages.json at rest.
# Leave empty to auto-derive from OWNER_NUMBER.
ENCRYPTION_KEY=""

# API key for Gifted Baileys extended media features
GIFTED_API_KEY="gifted"


# ── Telegram Crash Reporting (Optional) ──────────────────
# Create a bot at @BotFather and get a Chat ID via @userinfobot
TG_BOT_TOKEN=""
TG_CHAT_ID=""
