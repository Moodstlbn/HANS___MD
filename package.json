{
  "name": "hans___md",
  "version": "2.2.1",
  "description": "HANS MD WhatsApp bot (Baileys v7 master, CommonJS)",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "pm2 start ecosystem.config.js --attach",
    "start:direct": "node index.js",
    "gen:protobuf": "sh WAProto/GenerateStatics.sh",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "stop": "pm2 stop HANS-MD",
    "restart": "pm2 restart HANS-MD",
    "logs": "pm2 logs HANS-MD",
    "dev": "node index.js"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "npm:@itsliaaa/baileys@latest",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.5",
    "gifted": "npm:gifted-baileys@^2.5.8",
    "megajs": "^1.3.10",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.3",
    "pm2": "^5.3.0",
    "qrcode-terminal": "^0.12.0",
    "yt-search": "^2.13.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "baileys"
    ],
    "ignoredBuiltDependencies": [
      "@whiskeysockets/baileys",
      "protobufjs",
      "sharp"
    ]
  },
  "allowScripts": {
    "@itsliaaa/baileys@0.3.18-final": true,
    "protobufjs@7.6.5": true
  }
}
